<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="false">
        <!-- Cloudinary CDN -->
        <domain includeSubdomains="true">res.cloudinary.com</domain>
        <domain includeSubdomains="true">api.cloudinary.com</domain>
        <!-- Google services used by Sign-In -->
        <domain includeSubdomains="true">googleapis.com</domain>
        <!-- Algolia Search -->
        <domain includeSubdomains="true">algolia.net</domain>
        <domain includeSubdomains="true">algolianet.com</domain>
        <!-- GitHub release updates -->
        <domain includeSubdomains="true">github.com</domain>
        <domain includeSubdomains="true">api.github.com</domain>
        <domain includeSubdomains="true">githubusercontent.com</domain>
        <!-- Hugging Face Space backend -->
        <domain includeSubdomains="true">hf.space</domain>
        <domain includeSubdomains="true">huggingface.co</domain>
    </domain-config>
</network-security-config>
